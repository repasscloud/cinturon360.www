---
const segments = [
  {
    icon: '🏢',
    title: 'Travel Management Companies',
    description:
      'The primary audience for Cinturon360. Replace Tramada and legacy mid-office tools with a modern platform built around how TMCs actually operate — client management, automation, integrations, and reporting at scale.',
    href: '/for-tmcs',
    color: 'sky',
    tags: ['Tramada replacement', 'Client management', 'Automation'],
  },
  {
    icon: '💼',
    title: 'Corporate Travel Programs',
    description:
      'For CFOs, travel managers, and procurement teams who need pre-trip approvals, policy enforcement, and finance-grade spend visibility — without changing the way they book.',
    href: '/for-corporates',
    color: 'purple',
    tags: ['Pre-trip approvals', 'Spend visibility', 'Compliance'],
  },
  {
    icon: '🏛️',
    title: 'Government & Controlled Environments',
    description:
      'Structured governance, audit-grade records, and defensible approval workflows for travel programs operating under strict compliance and accountability requirements.',
    href: '/for-corporates',
    color: 'emerald',
    tags: ['Audit trail', 'Defensible records', 'Strict governance'],
  },
  {
    icon: '✈️',
    title: 'Leisure & High-Net-Worth Travel',
    description:
      'Precision oversight for premium leisure programs and HNW personal travel. Policy, approvals, and visibility tools for advisors managing clients who expect discretion and quality.',
    href: '/for-leisure',
    color: 'orange',
    tags: ['Premium programs', 'Advisor tools', 'HNW clients'],
  },
];

type SegColor = 'sky' | 'purple' | 'emerald' | 'orange';

const colorMap: Record<SegColor, { bg: string; tag: string; dot: string }> = {
  sky:    { bg: 'bg-sky-50',    tag: 'bg-sky-100 text-sky-700',    dot: 'bg-sky-400' },
  purple: { bg: 'bg-purple-50', tag: 'bg-purple-100 text-purple-700', dot: 'bg-purple-400' },
  emerald:{ bg: 'bg-emerald-50',tag: 'bg-emerald-100 text-emerald-700', dot: 'bg-emerald-400' },
  orange: { bg: 'bg-orange-50', tag: 'bg-orange-100 text-orange-700', dot: 'bg-orange-400' },
};
---

<section class="section bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    <div class="text-center mb-16">
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-sky-100 text-sky-700 mb-4">
        Who we serve
      </span>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-slate-900 mb-4">
        One platform, every tier of managed travel
      </h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">
        TMCs run on Cinturon360. Their corporate, government, and leisure clients benefit from it.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {segments.map((seg) => {
        const c = colorMap[seg.color as SegColor];
        return (
          <div class="card group hover:shadow-lg transition-shadow duration-200">
            <div class={`w-12 h-12 rounded-xl flex items-center justify-center mb-4 text-2xl ${c.bg}`}>
              {seg.icon}
            </div>
            <h3 class="font-heading text-xl font-bold text-slate-900 mb-3">{seg.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed mb-4">{seg.description}</p>
            <div class="flex flex-wrap gap-2 mb-4">
              {seg.tags.map((tag) => (
                <span class={`inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium ${c.tag}`}>
                  {tag}
                </span>
              ))}
            </div>
            <a
              href={seg.href}
              class="inline-flex items-center gap-1 text-sm font-medium text-sky-600 hover:text-sky-700 transition-colors"
            >
              Explore
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        );
      })}
    </div>
  </div>
</section>
