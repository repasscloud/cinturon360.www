---
const logos = [
  { name: 'Amadeus', src: '/images/logos/amadeus.svg' },
  { name: 'Sabre', src: '/images/logos/sabre.svg' },
  { name: 'Travelport', src: '/images/logos/travelport.svg' },
  { name: 'Duffel', src: '/images/logos/duffel.svg' },
  { name: 'AirGateway', src: '/images/logos/airgateway.svg' },
];
---

<section class="py-12 border-y border-slate-100 bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    <p class="text-center text-sm font-medium text-slate-400 uppercase tracking-wider mb-8">
      Works with the travel ecosystem you already use
    </p>
    <div class="flex flex-wrap items-center justify-center gap-8 md:gap-16">
      {logos.map((logo) => (
        <div class="flex items-center justify-center h-8">
          <img
            src={logo.src}
            alt={logo.name}
            class="h-6 md:h-8 w-auto object-contain grayscale hover:grayscale-0 opacity-60 hover:opacity-100 transition-all duration-200"
          />
        </div>
      ))}
    </div>
  </div>
</section>
