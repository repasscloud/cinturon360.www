---
export interface Props {
  badge?: string;
  headline?: string;
  subheadline?: string;
  supportText?: string;
  primaryCTA?: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
}

const {
  badge = 'TMC-first travel platform',
  headline = 'The operating layer your TMC has been missing.',
  subheadline = 'Cinturon360 replaces legacy back-office complexity with modern governance, automation, and finance-grade reporting — without forcing you to change how you book.',
  supportText = 'Works alongside GDS, NDC, direct suppliers, and your existing TMC workflows. No rip-and-replace.',
  primaryCTA = { label: 'Built for TMCs', href: '/for-tmcs' },
  secondaryCTA = { label: 'Join Waitlist', href: '/waitlist' },
} = Astro.props;
---

<section
  class="relative overflow-hidden pt-32 pb-24 md:pt-40 md:pb-32"
  style="background: linear-gradient(30deg, #38bdf833 0%, #0f172a 60%);"
>
  <!-- Background glow blobs -->
  <div
    class="absolute -top-20 -left-20 w-96 h-96 rounded-full opacity-20 blur-3xl pointer-events-none"
    style="background: #38bdf8;"
  ></div>
  <div
    class="absolute top-40 right-0 w-72 h-72 rounded-full opacity-10 blur-3xl pointer-events-none"
    style="background: #f97316;"
  ></div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl relative">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Badge -->
      <div class="flex justify-center mb-8">
        <span class="hero-badge">
          <span class="w-1.5 h-1.5 rounded-full bg-sky-400 animate-pulse"></span>
          {badge}
        </span>
      </div>

      <!-- Headline -->
      <h1 class="font-heading text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
        {headline}
      </h1>

      <!-- Sub-headline -->
      <p class="text-lg md:text-xl text-slate-300 mb-4 max-w-3xl mx-auto leading-relaxed">
        {subheadline}
      </p>

      <!-- Support text -->
      {supportText && (
        <p class="text-sm text-slate-500 mb-10">
          {supportText}
        </p>
      )}

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={primaryCTA.href}
          class="btn-primary text-base px-8 py-4"
        >
          {primaryCTA.label}
        </a>
        <a
          href={secondaryCTA.href}
          class="btn-outline text-base px-8 py-4"
        >
          {secondaryCTA.label}
        </a>
      </div>
    </div>
  </div>
</section>
