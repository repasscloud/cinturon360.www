---
export interface Props {
  title?: string;
  description?: string;
  primaryCTA?: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
}

const {
  title = 'Ready to replace legacy with modern?',
  description = 'Cinturon360 is in active development. TMCs and design partners are joining now to shape the platform. Get early access and be first to go live.',
  primaryCTA = { label: 'Join Waitlist', href: '/waitlist' },
  secondaryCTA = { label: 'Book a Conversation', href: '/contact' },
} = Astro.props;
---

<section
  class="py-16 md:py-24"
  style="background: linear-gradient(30deg, #38bdf833 0%, #0f172a 70%);"
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-4">
        {title}
      </h2>
      <p class="text-slate-300 text-lg mb-10 leading-relaxed">
        {description}
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={primaryCTA.href} class="btn-primary text-base px-8 py-4">
          {primaryCTA.label}
        </a>
        <a href={secondaryCTA.href} class="btn-outline text-base px-8 py-4">
          {secondaryCTA.label}
        </a>
      </div>
    </div>
  </div>
</section>
