---
// Formspree action: xnjgpyqy
---

<form
  action="https://formspree.io/f/xnjgpyqy"
  method="POST"
  class="space-y-5"
>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <label for="first-name" class="form-label">First name</label>
      <input type="text" id="first-name" name="first_name" required
        class="form-input" placeholder="Jane" autocomplete="given-name" />
    </div>
    <div>
      <label for="last-name" class="form-label">Last name</label>
      <input type="text" id="last-name" name="last_name" required
        class="form-input" placeholder="Smith" autocomplete="family-name" />
    </div>
  </div>

  <div>
    <label for="email" class="form-label">Work email</label>
    <input type="email" id="email" name="email" required
      class="form-input" placeholder="jane@yourtmc.com" autocomplete="email" />
  </div>

  <div>
    <label for="organisation" class="form-label">Organisation</label>
    <input type="text" id="organisation" name="organisation"
      class="form-input" placeholder="Acme Travel Co." autocomplete="organization" />
  </div>

  <div>
    <label for="enquiry-type" class="form-label">Enquiry type</label>
    <select id="enquiry-type" name="enquiry_type" class="form-input">
      <option value="">Select an option</option>
      <option value="tmc">TMC partnership / design partner</option>
      <option value="api">API and integration discussions</option>
      <option value="corporate">Corporate travel program</option>
      <option value="investment">Investment / pre-seed round</option>
      <option value="partnership">Technology or implementation partner</option>
      <option value="early-access">Early access enquiry</option>
      <option value="other">Other</option>
    </select>
  </div>

  <div>
    <label for="message" class="form-label">Message</label>
    <textarea id="message" name="message" rows="4" required
      class="form-input resize-none"
      placeholder="Tell us about your travel program or enquiry..."></textarea>
  </div>

  <button type="submit" class="btn-primary w-full py-3.5 text-sm font-semibold">
    Send Message
    <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </button>
</form>
