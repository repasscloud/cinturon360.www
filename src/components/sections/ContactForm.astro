---
// Formspree action: xnjgpyqy
---

<form
  action="https://formspree.io/f/xnjgpyqy"
  method="POST"
  class="space-y-5 max-w-xl"
>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    <div>
      <label for="first-name" class="block text-sm font-medium text-slate-700 mb-1.5">
        First name
      </label>
      <input
        type="text"
        id="first-name"
        name="first_name"
        required
        class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-sky-400 focus:ring-1 focus:ring-sky-400 focus:outline-none"
        placeholder="Jane"
      />
    </div>
    <div>
      <label for="last-name" class="block text-sm font-medium text-slate-700 mb-1.5">
        Last name
      </label>
      <input
        type="text"
        id="last-name"
        name="last_name"
        required
        class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-sky-400 focus:ring-1 focus:ring-sky-400 focus:outline-none"
        placeholder="Smith"
      />
    </div>
  </div>

  <div>
    <label for="email" class="block text-sm font-medium text-slate-700 mb-1.5">
      Email address
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-sky-400 focus:ring-1 focus:ring-sky-400 focus:outline-none"
      placeholder="jane@example.com"
    />
  </div>

  <div>
    <label for="organisation" class="block text-sm font-medium text-slate-700 mb-1.5">
      Organisation
    </label>
    <input
      type="text"
      id="organisation"
      name="organisation"
      class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-sky-400 focus:ring-1 focus:ring-sky-400 focus:outline-none"
      placeholder="Acme Travel Co."
    />
  </div>

  <div>
    <label for="enquiry-type" class="block text-sm font-medium text-slate-700 mb-1.5">
      Enquiry type
    </label>
    <select
      id="enquiry-type"
      name="enquiry_type"
      class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm text-slate-900 focus:border-sky-400 focus:ring-1 focus:ring-sky-400 focus:outline-none"
    >
      <option value="">Select an option</option>
      <option value="early-access">Early access and platform updates</option>
      <option value="tmc">TMC onboarding and client use cases</option>
      <option value="api">API and integration discussions</option>
      <option value="partnership">Partnership opportunities</option>
      <option value="commercial">Implementation and commercial conversations</option>
      <option value="other">Other</option>
    </select>
  </div>

  <div>
    <label for="message" class="block text-sm font-medium text-slate-700 mb-1.5">
      Message
    </label>
    <textarea
      id="message"
      name="message"
      rows="5"
      required
      class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm text-slate-900 placeholder:text-slate-400 focus:border-sky-400 focus:ring-1 focus:ring-sky-400 focus:outline-none resize-none"
      placeholder="Tell us about your travel program or enquiry..."
    ></textarea>
  </div>

  <button
    type="submit"
    class="btn-primary w-full text-sm py-3"
  >
    Send Message
  </button>
</form>
