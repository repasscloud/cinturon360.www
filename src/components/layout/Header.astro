---
const navLinks = [
  { label: 'For TMCs', href: '/for-tmcs' },
  { label: 'API', href: '/api' },
  { label: 'Blog', href: '/blog' },
  { label: 'About', href: '/about' },
];

const platformLinks = [
  { label: 'Policy & Approvals', href: '/platform/policy-approvals', icon: '🛡️' },
  { label: 'Integrations', href: '/platform/integrations', icon: '🔗' },
  { label: 'Reporting & Visibility', href: '/platform/reporting-visibility', icon: '📊' },
  { label: 'TMC Operations', href: '/platform/tmc-operations', icon: '⚙️' },
  { label: 'Performance & Scale', href: '/platform/performance-scale', icon: '📈' },
  { label: 'Developer Experience', href: '/platform/developer-experience', icon: '🔌' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="fixed top-0 left-0 right-0 z-50"
  style="background: rgba(5, 8, 15, 0.92); border-bottom: 1px solid rgba(255,255,255,0.07); backdrop-filter: blur(16px);"
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 flex-shrink-0 group">
        <span class="font-heading font-extrabold text-xl tracking-tight">
          <span style="color: #38bdf8;">Cinturon</span><span style="color: #f97316;">360</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1">

        <!-- Platform dropdown -->
        <div class="relative group">
          <button
            class="nav-link flex items-center gap-1 px-3 py-2 rounded-lg hover:bg-white/5 transition-all"
            aria-haspopup="true"
          >
            Platform
            <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Dropdown -->
          <div
            class="absolute left-0 top-full mt-3 w-64 rounded-2xl py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 shadow-2xl"
            style="background: rgba(13, 20, 36, 0.98); border: 1px solid rgba(255,255,255,0.1);"
          >
            {platformLinks.map((link) => (
              <a
                href={link.href}
                class={`flex items-center gap-3 px-4 py-2.5 text-sm transition-colors duration-150 ${
                  currentPath === link.href
                    ? 'text-sky-400 bg-white/5'
                    : 'text-slate-300 hover:text-white hover:bg-white/5'
                }`}
              >
                <span class="text-base">{link.icon}</span>
                {link.label}
              </a>
            ))}
          </div>
        </div>

        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`nav-link px-3 py-2 rounded-lg hover:bg-white/5 transition-all ${currentPath === link.href || currentPath.startsWith(link.href + '/') ? '!text-white bg-white/5' : ''}`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right actions -->
      <div class="hidden lg:flex items-center gap-3">
        <a href="/waitlist"
          class="text-sm font-medium px-4 py-2 rounded-full transition-colors"
          style="color: rgba(248,250,252,0.65);"
          onmouseover="this.style.color='#fff'; this.style.background='rgba(255,255,255,0.07)';"
          onmouseout="this.style.color='rgba(248,250,252,0.65)'; this.style.background='transparent';"
        >
          Join Waitlist
        </a>
        <a href="/contact" class="btn-primary text-sm px-5 py-2.5">
          Reach Out
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-xl transition-colors"
        style="color: rgba(248,250,252,0.7);"
        aria-label="Open menu"
      >
        <svg id="menu-icon-open" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden"
    style="border-top: 1px solid rgba(255,255,255,0.07); background: rgba(5,8,15,0.98);"
  >
    <div class="px-4 py-5 space-y-1">
      <!-- Platform section -->
      <p class="text-xs font-semibold uppercase tracking-widest px-3 mb-3" style="color: rgba(248,250,252,0.3);">Platform</p>
      {platformLinks.map((link) => (
        <a href={link.href}
          class="flex items-center gap-3 px-3 py-2.5 text-sm rounded-xl transition-colors text-slate-300 hover:text-white hover:bg-white/5">
          <span>{link.icon}</span>
          {link.label}
        </a>
      ))}

      <div class="my-3" style="border-top: 1px solid rgba(255,255,255,0.07);"></div>

      {navLinks.map((link) => (
        <a href={link.href}
          class="flex px-3 py-2.5 text-sm rounded-xl transition-colors text-slate-300 hover:text-white hover:bg-white/5">
          {link.label}
        </a>
      ))}

      <div class="pt-4 flex flex-col gap-3">
        <a href="/waitlist"
          class="block text-center px-4 py-2.5 text-sm rounded-full font-medium"
          style="border: 1px solid rgba(56,189,248,0.3); color: #38bdf8; background: rgba(56,189,248,0.06);">
          Join Waitlist
        </a>
        <a href="/contact"
          class="block text-center px-4 py-2.5 text-sm font-semibold rounded-full"
          style="background: #38bdf8; color: #05080f; box-shadow: 0 0 20px rgba(56,189,248,0.3);">
          Reach Out
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isHidden = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !isHidden ? false : true);
    iconClose?.classList.toggle('hidden', !isHidden ? true : false);
  });
</script>
