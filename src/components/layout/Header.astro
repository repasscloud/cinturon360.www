---
const navLinks = [
  { label: 'For TMCs', href: '/for-tmcs' },
  { label: 'API', href: '/api' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const platformLinks = [
  { label: 'Policy & Approvals', href: '/platform/policy-approvals' },
  { label: 'Integrations', href: '/platform/integrations' },
  { label: 'Reporting & Visibility', href: '/platform/reporting-visibility' },
  { label: 'TMC Operations', href: '/platform/tmc-operations' },
  { label: 'Performance & Scale', href: '/platform/performance-scale' },
  { label: 'Developer Experience', href: '/platform/developer-experience' },
];

const currentPath = Astro.url.pathname;
---

<header
  class="fixed top-0 left-0 right-0 z-50 border-b"
  style="background: rgba(15, 23, 42, 0.98); border-color: rgba(255,255,255,0.08);"
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 flex-shrink-0">
        <img src="/images/logo.svg" alt="Cinturon360" class="h-8 w-auto" />
        <span class="font-heading font-bold text-lg">
          <span style="color: #38bdf8;">Cinturon</span><span style="color: #f97316;">360</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center space-x-8">
        <!-- Platform dropdown -->
        <div class="relative group">
          <button
            class="nav-link flex items-center gap-1"
            aria-haspopup="true"
          >
            Platform
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Dropdown -->
          <div
            class="absolute left-0 top-full mt-2 w-56 rounded-xl border shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2"
            style="background: rgba(15, 23, 42, 0.98); border-color: rgba(255,255,255,0.12);"
          >
            {platformLinks.map((link) => (
              <a
                href={link.href}
                class={`block px-4 py-2.5 text-sm transition-colors duration-150 ${
                  currentPath.startsWith(link.href)
                    ? 'text-sky-400 bg-white/5'
                    : 'text-slate-300 hover:text-white hover:bg-white/5'
                }`}
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>

        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`nav-link ${currentPath === link.href ? 'text-white' : ''}`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right actions -->
      <div class="hidden md:flex items-center gap-3">
        <a href="/waitlist" class="btn-ghost text-sm px-4 py-2 text-slate-300 hover:text-white hover:bg-white/5 rounded-full transition-colors">
          Join Waitlist
        </a>
        <a href="/contact" class="btn-primary text-sm">
          Reach Out
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-slate-300 hover:text-white hover:bg-white/10 transition-colors"
        aria-label="Open menu"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t"
    style="border-color: rgba(255,255,255,0.08);"
  >
    <div class="px-4 py-4 space-y-1">
      <div class="pb-2 mb-2 border-b" style="border-color: rgba(255,255,255,0.08);">
        <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider px-3 mb-2">Platform</p>
        {platformLinks.map((link) => (
          <a
            href={link.href}
            class="block px-3 py-2 text-sm text-slate-300 hover:text-white hover:bg-white/5 rounded-lg transition-colors"
          >
            {link.label}
          </a>
        ))}
      </div>
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block px-3 py-2 text-sm text-slate-300 hover:text-white hover:bg-white/5 rounded-lg transition-colors"
        >
          {link.label}
        </a>
      ))}
      <div class="pt-3 flex flex-col gap-2">
        <a href="/waitlist" class="block text-center px-4 py-2 text-sm text-slate-300 border border-white/20 rounded-full hover:bg-white/5 transition-colors">
          Join Waitlist
        </a>
        <a href="/contact" class="block text-center px-4 py-2 text-sm font-semibold bg-sky-400 text-slate-900 rounded-full hover:bg-sky-300 transition-colors">
          Reach Out
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
