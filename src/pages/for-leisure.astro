---
import PageLayout from '../layouts/PageLayout.astro';
import CTA from '../components/sections/CTA.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Cinturon360 for Leisure and High-Net-Worth Travel',
  url: 'https://cinturon360.com/for-leisure',
  description: 'Structured governance and visibility for premium leisure travel — approval workflows, spend oversight, and audit trails for travel advisors managing discerning clients.',
  audience: { '@type': 'Audience', audienceType: 'Leisure Travel Advisors and High-Net-Worth Travellers' },
  provider: { '@type': 'Organization', name: 'Cinturon360' },
  serviceType: 'Leisure Travel Management',
};
---

<PageLayout
  title="For Leisure & High-Net-Worth Travel"
  description="Cinturon360 brings structured governance and visibility to premium leisure travel programs — approval workflows, spend oversight, and audit trails for travel advisors managing discerning clients."
  schema={schema}
>

  <!-- Hero -->
  <section
    class="relative overflow-hidden pt-32 pb-20 md:pb-24"
    style="background: var(--c360-dark);"
  >
    <div class="absolute -top-20 -left-20 w-96 h-96 rounded-full opacity-20 blur-3xl pointer-events-none" style="background: #f97316;"></div>
    <div class="absolute top-40 right-0 w-72 h-72 rounded-full opacity-10 blur-3xl pointer-events-none" style="background: #38bdf8;"></div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl relative">
      <div class="max-w-4xl mx-auto text-center">
        <div class="flex justify-center mb-8">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium border"
            style="background: rgba(249,115,22,0.15); border-color: rgba(249,115,22,0.3); color: #fb923c;">
            <span class="w-1.5 h-1.5 rounded-full bg-orange-400 animate-pulse"></span>
            For leisure & HNW travel
          </span>
        </div>
        <h1 class="font-heading text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
          Structured oversight for premium travel programs.
        </h1>
        <p class="text-lg md:text-xl text-slate-300 mb-4 max-w-3xl mx-auto leading-relaxed">
          Cinturon360 gives leisure travel advisors and HNW program managers the governance tools to deliver precision, discretion, and accountability — for clients who expect nothing less.
        </p>
        <p class="text-sm text-slate-400 mb-10">
          Policy, approvals, and spend visibility for premium and complex leisure travel programs.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/contact" class="btn-primary text-base px-8 py-4">
            Contact Us
          </a>
          <a href="/waitlist" class="btn-outline text-base px-8 py-4">
            Join Waitlist
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Value props -->
  <section class="section bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="text-center mb-16">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-slate-900 mb-4">
          Precision tools for exceptional programs
        </h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          Complex leisure and HNW travel requires more than booking capability. It requires structured management, clear accountability, and visibility that clients can trust.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            icon: '✅',
            title: 'Approval workflows for personal travel',
            body: 'Configure approval chains for family, personal, or group travel programs. Define rules by traveller, budget, destination, or itinerary type. Every booking is on record.',
          },
          {
            icon: '📊',
            title: 'Spend visibility across programs',
            body: 'Track travel spend across individuals, families, or programs in real time. Reporting structured for advisor review, family office use, or personal financial management.',
          },
          {
            icon: '🔒',
            title: 'Discretion and data security',
            body: 'Built with enterprise-grade security and hosted in Australia. Client data stays in-region, and access controls ensure only authorised parties see sensitive itinerary and spend data.',
          },
          {
            icon: '📋',
            title: 'Policy for personal programs',
            body: 'Even personal travel programs benefit from rules — preferred suppliers, budget guardrails, approval requirements for high-value bookings. Cinturon360 makes these configurable and enforceable.',
          },
          {
            icon: '🌏',
            title: 'Built for APAC — designed globally',
            body: 'APAC-hosted with multi-currency support and timezone-aware workflows. Designed to serve clients travelling globally from an APAC base of operations.',
          },
          {
            icon: '🤝',
            title: 'Advisor-first tooling',
            body: 'Cinturon360 is a platform for advisors to run exceptional programs, not a tool that displaces them. The platform does the administration — you focus on the client relationship.',
          },
        ].map((item) => (
          <div class="card">
            <div class="w-10 h-10 rounded-lg bg-orange-50 flex items-center justify-center text-xl mb-4">{item.icon}</div>
            <h3 class="font-heading text-lg font-bold text-slate-900 mb-2">{item.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title="Managing a premium travel program?"
    description="Speak with the team about how Cinturon360 can bring structured governance and visibility to your leisure or HNW travel advisory practice."
    primaryCTA={{ label: 'Contact Us', href: '/contact' }}
    secondaryCTA={{ label: 'Join Waitlist', href: '/waitlist' }}
  />

</PageLayout>
