---
import PageLayout from '../layouts/PageLayout.astro';
import CTA from '../components/sections/CTA.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Cinturon360 for Corporate Travel Programs',
  url: 'https://cinturon360.com/for-corporates',
  description: 'Pre-trip approvals, policy enforcement, and finance-grade spend visibility for CFOs, travel managers, and procurement teams.',
  audience: { '@type': 'Audience', audienceType: 'Corporate Travel Managers and CFOs' },
  provider: { '@type': 'Organization', name: 'Cinturon360' },
  serviceType: 'Corporate Travel Management',
};
---

<PageLayout
  title="For Corporate Travel Programs"
  description="Cinturon360 gives CFOs, travel managers, and procurement teams pre-trip approvals, policy enforcement, and finance-grade spend visibility — without changing how they book."
  schema={schema}
>

  <!-- Hero -->
  <section
    class="relative overflow-hidden pt-32 pb-20 md:pb-24"
    style="background: var(--c360-dark);"
  >
    <div class="absolute -top-20 -left-20 w-96 h-96 rounded-full opacity-20 blur-3xl pointer-events-none" style="background: #a855f7;"></div>
    <div class="absolute top-40 right-0 w-72 h-72 rounded-full opacity-10 blur-3xl pointer-events-none" style="background: #38bdf8;"></div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl relative">
      <div class="max-w-4xl mx-auto text-center">
        <div class="flex justify-center mb-8">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium border"
            style="background: rgba(168,85,247,0.15); border-color: rgba(168,85,247,0.3); color: #c084fc;">
            <span class="w-1.5 h-1.5 rounded-full bg-purple-400 animate-pulse"></span>
            For corporate travel programs
          </span>
        </div>
        <h1 class="font-heading text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
          Full visibility over every dollar your people spend on travel.
        </h1>
        <p class="text-lg md:text-xl text-slate-300 mb-4 max-w-3xl mx-auto leading-relaxed">
          Cinturon360 gives finance, procurement, and travel management teams pre-trip approvals, policy enforcement at booking, and CFO-ready spend reporting — all without changing your TMC relationship or booking channel.
        </p>
        <p class="text-sm text-slate-400 mb-10">
          Works alongside your existing TMC. No new booking tool required.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/contact" class="btn-primary text-base px-8 py-4">
            Talk to Us
          </a>
          <a href="/waitlist" class="btn-outline text-base px-8 py-4">
            Join Waitlist
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Core value props -->
  <section class="section bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="text-center mb-16">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-slate-900 mb-4">
          What corporate travel programs get
        </h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          Governance tools that sit above the booking layer, so spend is controlled before it's committed — not reconciled after.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {[
          {
            icon: '✅',
            color: 'purple',
            title: 'Pre-trip approvals',
            body: 'Require approval before any travel is booked. Configure approval chains by team, department, destination, cost centre, or spend threshold. Approvers get notified instantly — no chasing email threads.',
          },
          {
            icon: '📋',
            color: 'sky',
            title: 'Policy enforcement at booking',
            body: 'Policy rules are applied at the point of booking, not after the fact. Out-of-policy bookings are flagged, escalated, or blocked — and every exception is logged with a reason.',
          },
          {
            icon: '📊',
            color: 'emerald',
            title: 'Finance-grade spend reporting',
            body: 'Real-time visibility across all travel spend by segment, department, traveller, and cost centre. Export-ready for finance review, board reporting, or audit. Not Excel — structured data.',
          },
          {
            icon: '🔍',
            color: 'orange',
            title: 'Full audit trail',
            body: 'Every booking, approval, exception, and policy change is logged with timestamps and actor IDs. Defensible records for compliance, internal audit, and regulatory review.',
          },
          {
            icon: '🏢',
            color: 'purple',
            title: 'Works with your TMC',
            body: 'Cinturon360 doesn\'t replace your TMC. It gives your TMC better tools to manage your program — and gives your finance team visibility that was previously only available on request.',
          },
          {
            icon: '🏛️',
            color: 'emerald',
            title: 'Government and controlled environments',
            body: 'Audit-grade governance for travel programs operating under strict accountability requirements. Structured approvals, defensible records, and compliance reporting built in.',
          },
        ].map((item) => (
          <div class="card">
            <div class={`w-10 h-10 rounded-lg flex items-center justify-center text-xl mb-4 ${
              item.color === 'purple' ? 'bg-purple-50' :
              item.color === 'sky' ? 'bg-sky-50' :
              item.color === 'emerald' ? 'bg-emerald-50' : 'bg-orange-50'
            }`}>{item.icon}</div>
            <h3 class="font-heading text-lg font-bold text-slate-900 mb-2">{item.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works with your TMC -->
  <section class="section bg-slate-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="max-w-3xl mx-auto text-center">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-sky-100 text-sky-700 mb-4">
          No disruption to your booking workflow
        </span>
        <h2 class="font-heading text-3xl font-bold text-slate-900 mb-6">
          The governance layer above your booking channel
        </h2>
        <p class="text-slate-600 text-lg leading-relaxed mb-8">
          Cinturon360 sits above your existing booking flow. Your travellers book the way they always have — through your TMC, GDS, or direct channel. Cinturon360 applies policy, routes approvals, captures data, and delivers the reporting your finance team needs. Nothing changes for travellers. Everything changes for visibility.
        </p>
        <a href="/platform/integrations" class="inline-flex items-center gap-2 text-sm font-medium text-sky-600 hover:text-sky-700 transition-colors">
          See how integrations work →
        </a>
      </div>
    </div>
  </section>

  <CTA
    title="Get control of your travel spend."
    description="Talk to the team about how Cinturon360 can give your finance and travel management teams the visibility and governance they need — without disrupting your existing program."
    primaryCTA={{ label: 'Talk to Us', href: '/contact' }}
    secondaryCTA={{ label: 'Join Waitlist', href: '/waitlist' }}
  />

</PageLayout>
