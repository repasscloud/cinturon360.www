---
import PageLayout from '../../layouts/PageLayout.astro';
import CTA from '../../components/sections/CTA.astro';
---

<PageLayout
  title="Integrations"
  description="Cinturon360 connects to GDS, NDC, direct suppliers, TMC workflows, and downstream finance systems — without replacing what already works."
>
  <div class="pt-24 pb-16" style="background: linear-gradient(to bottom, #faf5ff, #ffffff);">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="max-w-3xl">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-700 mb-4">
          Integrations
        </span>
        <h1 class="font-heading text-4xl md:text-5xl font-bold text-slate-900 mb-6">
          Works with the ecosystem you already use
        </h1>
        <p class="text-xl text-slate-600 leading-relaxed">
          Cinturon360 is not a rip-and-replace online booking tool. It wraps around your current channels so you can govern bookings made through TMCs, GDS/NDC, direct suppliers, and other connected sources.
        </p>
      </div>
    </div>
  </div>

  <!-- Integration ecosystem -->
  <div class="section bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <h2 class="font-heading text-3xl font-bold text-slate-900 text-center mb-4">Integration ecosystem</h2>
      <p class="text-slate-600 text-center max-w-2xl mx-auto mb-12">
        Cinturon360 is designed to sit above the booking layer and receive data from whatever channels your organisation or TMC clients use.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        {[
          {
            title: 'Booking Sources',
            icon: '✈️',
            items: ['GDS-connected environments', 'NDC pathways', 'TMC-managed workflows', 'Direct supplier channels', 'Client-specific booking processes'],
          },
          {
            title: 'Downstream Systems',
            icon: '📤',
            items: ['Finance and ERP handoff', 'Expense platform connections', 'Reporting and BI pipelines', 'Procurement system outputs', 'Cost allocation exports'],
          },
          {
            title: 'Platform Connectivity',
            icon: '🔌',
            items: ['REST API for custom integrations', 'Webhook event delivery', 'Identity provider connections', 'Partner and TMC connectors', 'Extension points for custom workflows'],
          },
        ].map((group) => (
          <div class="card">
            <div class="text-3xl mb-3">{group.icon}</div>
            <h3 class="font-heading text-lg font-bold text-slate-900 mb-3">{group.title}</h3>
            <ul class="space-y-2">
              {group.items.map((item) => (
                <li class="flex items-start gap-2 text-sm text-slate-600">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-purple-400 flex-shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Partner logos -->
      <div class="bg-slate-50 rounded-2xl p-8">
        <p class="text-center text-sm font-medium text-slate-500 uppercase tracking-wider mb-6">
          Designed to work alongside
        </p>
        <div class="flex flex-wrap items-center justify-center gap-8 md:gap-16">
          {[
            { name: 'Amadeus', src: '/images/logos/amadeus.svg' },
            { name: 'Sabre', src: '/images/logos/sabre.svg' },
            { name: 'Travelport', src: '/images/logos/travelport.svg' },
            { name: 'Duffel', src: '/images/logos/duffel.svg' },
            { name: 'AirGateway', src: '/images/logos/airgateway.svg' },
          ].map((logo) => (
            <img src={logo.src} alt={logo.name} class="h-7 w-auto grayscale opacity-60 hover:opacity-100 hover:grayscale-0 transition-all" />
          ))}
        </div>
      </div>
    </div>
  </div>

  <CTA />
</PageLayout>
