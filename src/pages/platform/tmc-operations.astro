---
import PageLayout from '../../layouts/PageLayout.astro';
import CTA from '../../components/sections/CTA.astro';
---

<PageLayout
  title="TMC Operations"
  description="Cinturon360 helps travel management companies onboard clients faster, manage client programs at scale, and deliver a more consistent service model."
>
  <div class="pt-24 pb-16" style="background: linear-gradient(to bottom, #fff7ed, #ffffff);">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="max-w-3xl">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-orange-100 text-orange-700 mb-4">
          TMC Operations
        </span>
        <h1 class="font-heading text-4xl md:text-5xl font-bold text-slate-900 mb-6">
          A stronger operating platform for TMCs
        </h1>
        <p class="text-xl text-slate-600 leading-relaxed">
          Travel management companies need more than booking support. They need a platform that helps them onboard clients, apply governance, manage integrations, and scale service delivery with confidence.
        </p>
      </div>
    </div>
  </div>

  <div class="section bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
        {[
          { icon: '⚡', title: 'Faster Client Onboarding', description: 'Bring new clients into a controlled operating environment without treating each account as a custom rebuild. Cinturon360 is being designed to make structured onboarding repeatable across organisational structure, traveller setup, policy, and integrations.' },
          { icon: '🏗️', title: 'Client-Specific Operating Models', description: 'Every client can have its own approval structures, travel policies, reporting expectations, booking channel mix, and integration needs. Manage that complexity without relying on manual workarounds and fragmented systems.' },
          { icon: '🔒', title: 'Secure Client Management', description: 'Maintain clear separation between client environments. Role-based access, client boundaries, and structured user management give TMCs and their clients confidence in how the platform is controlled.' },
          { icon: '🔄', title: 'Self-Service That Supports TMCs', description: 'Give clients visibility into their own travel program — spend, approvals, policy position — without removing the TMC from the service model. Self-service that helps clients without bypassing the agency relationship.' },
        ].map((item) => (
          <div class="card">
            <div class="text-3xl mb-3">{item.icon}</div>
            <h3 class="font-heading text-xl font-bold text-slate-900 mb-3">{item.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>

      <!-- Problems solved -->
      <div class="bg-orange-50 rounded-2xl border border-orange-100 p-8 md:p-10">
        <h2 class="font-heading text-2xl font-bold text-slate-900 mb-6">Problems Cinturon360 is designed to solve for TMCs</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {[
            'Slow and inconsistent client onboarding',
            'Client-by-client variation in operating models',
            'Fragmented approval and policy handling',
            'Disconnected visibility across client accounts',
            'Heavy manual servicing overhead',
            'Weak separation between client environments',
            'Limited standardisation at scale',
            'Difficulty connecting to diverse integration landscapes',
          ].map((problem) => (
            <div class="flex items-start gap-3">
              <span class="mt-1 w-5 h-5 rounded-full bg-orange-100 flex items-center justify-center flex-shrink-0">
                <svg class="w-3 h-3 text-orange-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </span>
              <span class="text-sm text-slate-700">{problem}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <CTA />
</PageLayout>
