---
import PageLayout from '../../layouts/PageLayout.astro';
import CTA from '../../components/sections/CTA.astro';

const platformPages = [
  {
    href: '/platform/policy-approvals',
    icon: '🛡️',
    badge: 'Governance',
    title: 'Policy & Approvals',
    description: 'Route bookings to the right approvers before spend is committed. Configurable approval chains, exception handling, and audit-grade decision records.',
  },
  {
    href: '/platform/tmc-operations',
    icon: '⚙️',
    badge: 'Automation',
    title: 'TMC Operations',
    description: 'Replace manual mid-office processes with repeatable workflow logic — from client onboarding to booking intake, quality control, and notifications.',
  },
  {
    href: '/platform/reporting-visibility',
    icon: '📊',
    badge: 'Visibility',
    title: 'Reporting & Visibility',
    description: 'Real-time, finance-grade spend reporting across every booking, approval, and exception. CFO-ready data — not another Excel export.',
  },
  {
    href: '/platform/integrations',
    icon: '🔗',
    badge: 'Integrations',
    title: 'Integrations',
    description: 'Native connectivity to Amadeus, Sabre, Travelport, Duffel, AirGateway, and direct suppliers. No rip-and-replace — works with what you have.',
  },
  {
    href: '/platform/performance-scale',
    icon: '📈',
    badge: 'Infrastructure',
    title: 'Performance & Scale',
    description: 'Cloud-native, APAC-hosted infrastructure that grows with booking volume and client complexity — without requiring a re-platform.',
  },
  {
    href: '/platform/developer-experience',
    icon: '🔌',
    badge: 'API',
    title: 'Developer Experience',
    description: 'API-first design — every platform capability accessible via REST API for TMC integrations, corporate system connections, and custom extensions.',
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'The Cinturon360 Platform',
  url: 'https://cinturon360.com/platform',
  description: 'A single platform combining governance, automation, and visibility for all types of travel management. Six core capability areas: policy approvals, TMC operations, reporting, integrations, scale, and developer API.',
  mainEntity: {
    '@type': 'SoftwareApplication',
    name: 'Cinturon360 Platform',
    featureList: [
      'Policy and approvals engine',
      'TMC operations and automation',
      'Finance-grade reporting',
      'GDS and NDC integrations',
      'Cloud-native performance and scale',
      'Developer REST API',
    ],
  },
};
---

<PageLayout
  title="Platform"
  description="Cinturon360 is a single platform combining governance, automation, and visibility for travel management companies. Explore the six capability areas."
  schema={schema}
>

  <!-- Hero -->
  <section class="relative overflow-hidden pt-32 pb-16" style="background: var(--c360-dark);">
    <div class="absolute -top-20 -left-20 w-96 h-96 rounded-full opacity-20 blur-3xl pointer-events-none" style="background: #38bdf8;"></div>
    <div class="absolute top-40 right-0 w-72 h-72 rounded-full opacity-10 blur-3xl pointer-events-none" style="background: #f97316;"></div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl relative">
      <div class="max-w-3xl">
        <div class="flex mb-8">
          <span class="hero-badge">
            <span class="w-1.5 h-1.5 rounded-full bg-sky-400 animate-pulse"></span>
            Platform overview
          </span>
        </div>
        <h1 class="font-heading text-4xl md:text-6xl font-bold text-white mb-4 leading-tight">
          One platform.<br />
          <span style="color: var(--c360-primary);">Six capability areas.</span>
        </h1>
        <p class="text-xl leading-relaxed" style="color: rgba(248,250,252,0.65);">
          Governance, automation, and visibility — built as a single system where policy, workflow, and reporting share the same data model.
        </p>
      </div>
    </div>
  </section>

  <!-- Capability grid -->
  <section class="section bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {platformPages.map((page) => (
          <a href={page.href}
            class="card group flex flex-col hover:shadow-md transition-shadow duration-200">
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 rounded-xl bg-sky-50 flex items-center justify-center text-2xl">
                {page.icon}
              </div>
              <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-slate-100 text-slate-600">
                {page.badge}
              </span>
            </div>
            <h2 class="font-heading text-lg font-bold text-slate-900 mb-2 group-hover:text-sky-700 transition-colors">
              {page.title}
            </h2>
            <p class="text-sm text-slate-600 leading-relaxed flex-1 mb-4">
              {page.description}
            </p>
            <span class="inline-flex items-center gap-1 text-sm font-medium text-sky-600 mt-auto">
              Learn more
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title="Want to see how it fits together?"
    description="Talk to the team about how Cinturon360 can work for your TMC or travel program."
    primaryCTA={{ label: 'Book a Conversation', href: '/contact' }}
    secondaryCTA={{ label: 'Join Waitlist', href: '/waitlist' }}
  />

</PageLayout>
