---
import PageLayout from '../../layouts/PageLayout.astro';
import CTA from '../../components/sections/CTA.astro';
---

<PageLayout
  title="Developer Experience"
  description="Cinturon360 is being built with developers in mind — a clean API, structured integration patterns, and extensible architecture for TMCs and partners."
>
  <div class="pt-24 pb-16 bg-gradient-to-b from-slate-900 to-slate-800">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="max-w-3xl">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium border border-sky-400/30 bg-sky-400/10 text-sky-300 mb-4">
          Developer Experience
        </span>
        <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">
          An API-first platform for integrators
        </h1>
        <p class="text-xl text-slate-300 leading-relaxed">
          Cinturon360 is being designed for the technical teams at TMCs and travel technology partners who need clean, reliable integration patterns to build on top of.
        </p>
      </div>
    </div>
  </div>

  <div class="section bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        {[
          { icon: '📡', title: 'REST API', description: 'Structured REST endpoints for all core capabilities — client management, travellers, policy, approvals, bookings, reporting, and webhooks.' },
          { icon: '🔔', title: 'Event-Driven Webhooks', description: 'Subscribe to events for approval outcomes, policy decisions, booking activity, and system state changes in real time.' },
          { icon: '🧩', title: 'Extensible Architecture', description: 'Extension points designed to support TMC-specific workflows, custom integrations, and partner-built capabilities on top of the core platform.' },
        ].map((item) => (
          <div class="card text-center">
            <div class="text-4xl mb-4">{item.icon}</div>
            <h3 class="font-heading text-xl font-bold text-slate-900 mb-3">{item.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>

      <!-- Developer notice -->
      <div class="max-w-2xl mx-auto bg-sky-50 border border-sky-200 rounded-2xl p-8 text-center">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-sky-100 text-sky-700 mb-4">
          In development
        </span>
        <h3 class="font-heading text-xl font-bold text-slate-900 mb-3">API documentation coming soon</h3>
        <p class="text-slate-600 text-sm mb-6 leading-relaxed">
          The Cinturon360 developer platform is currently in design and development. If you are a technical stakeholder or implementation partner, we'd welcome an early conversation.
        </p>
        <a href="/contact" class="btn-primary">Start a Conversation</a>
      </div>
    </div>
  </div>

  <CTA />
</PageLayout>
