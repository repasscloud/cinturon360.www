---
import PageLayout from '../../layouts/PageLayout.astro';
import CTA from '../../components/sections/CTA.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Developer Experience — Cinturon360',
  url: 'https://cinturon360.com/platform/developer-experience',
  description: 'API-first platform — every Cinturon360 capability accessible via REST API for TMC integrations, corporate HR/ERP connections, and third-party developers.',
  mainEntity: {
    '@type': 'WebAPI',
    name: 'Cinturon360 Developer API',
    documentation: 'https://cinturon360.com/api',
    featureList: ['Full REST API coverage', 'TMC system integrations', 'Corporate HR and ERP connectors', 'Third-party developer access'],
  },
};
---

<PageLayout
  title="Developer Experience"
  description="Cinturon360 is API-first. Every capability available in the platform is accessible via the REST API — for TMC integrations, corporate system connections, and third-party developer access."
  schema={schema}
>
  <div class="pt-32 pb-16" style="background: var(--c360-dark);">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="max-w-3xl">
        <span class="section-badge section-badge-primary mb-4">Platform — Developer Experience</span>
        <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-6">
          API-first. Every capability, accessible by code.
        </h1>
        <p class="text-xl leading-relaxed" style="color: rgba(248,250,252,0.55);">
          Cinturon360 is built API-first — every platform capability is accessible via the REST API. TMC integrations, corporate system connections, and custom workflow extensions all use the same API that powers the platform itself.
        </p>
      </div>
    </div>
  </div>

  <section class="section bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        {[
          {
            icon: '🔌',
            badge: 'REST API',
            badgeColor: 'bg-sky-100 text-sky-700',
            title: 'Full platform access',
            body: 'Bookings, approvals, policy rules, reporting queries, user management, and integration configuration — all available via a consistent REST API with standard authentication.',
          },
          {
            icon: '📄',
            badge: 'Documentation',
            badgeColor: 'bg-slate-100 text-slate-700',
            title: 'Developer documentation',
            body: 'API reference, integration guides, and code examples. Documentation is versioned alongside the API — you\'ll always know what changed and when.',
          },
          {
            icon: '🔐',
            badge: 'Auth & Access',
            badgeColor: 'bg-emerald-100 text-emerald-700',
            title: 'Secure by design',
            body: 'OAuth 2.0 authentication, API key management, rate limiting, and per-tenant access controls. TMC and corporate system integrations get scoped access, not blanket permissions.',
          },
        ].map((item) => (
          <div class="card">
            <div class="text-2xl mb-3">{item.icon}</div>
            <span class={`inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium mb-3 ${item.badgeColor}`}>
              {item.badge}
            </span>
            <h3 class="font-heading text-lg font-bold text-slate-900 mb-2">{item.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>

      <!-- Use cases -->
      <div class="bg-slate-50 rounded-2xl p-8 border border-slate-100">
        <h3 class="font-heading text-xl font-bold text-slate-900 mb-6">What developers use the API for</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {[
            { title: 'TMC system integrations', body: 'Connect proprietary TMC booking tools or back-office systems to the Cinturon360 governance and reporting layer.' },
            { title: 'Corporate ERP connections', body: 'Feed travel approval and spend data directly into SAP, Oracle, or other ERP systems via structured API output.' },
            { title: 'Custom workflow triggers', body: 'Trigger external actions on approval events — Slack notifications, internal ticketing systems, finance platform webhooks.' },
            { title: 'Reporting data pipelines', body: 'Pull structured travel spend and compliance data into BI tools, data warehouses, or custom finance dashboards.' },
          ].map((item) => (
            <div class="bg-white rounded-xl p-5 border border-slate-100">
              <h4 class="font-heading font-semibold text-slate-900 mb-1 text-sm">{item.title}</h4>
              <p class="text-slate-600 text-sm leading-relaxed">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Early access note -->
  <section class="section bg-slate-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-heading text-2xl font-bold text-slate-900 mb-4">
          API documentation coming soon
        </h2>
        <p class="text-slate-600 leading-relaxed mb-6">
          Full API reference and developer documentation are in progress and will be published alongside platform access. Early access partners and design partners can request API documentation directly.
        </p>
        <a href="/api" class="inline-flex items-center gap-2 text-sm font-medium text-sky-600 hover:text-sky-700 transition-colors">
          See the API overview →
        </a>
      </div>
    </div>
  </section>

  <CTA
    title="Building on top of <span style='color: var(--c360-primary);'>Cinturon</span><span style='color: var(--c360-accent);'>360</span>?"
    description="Talk to the team about early API access and integration partnerships for TMCs and developers."
    primaryCTA={{ label: 'Contact Us', href: '/contact' }}
    secondaryCTA={{ label: 'API Overview', href: '/api' }}
  />
</PageLayout>
