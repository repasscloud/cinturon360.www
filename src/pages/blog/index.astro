---
import PageLayout from '../../layouts/PageLayout.astro';
import CTA from '../../components/sections/CTA.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = posts[0];
const rest = posts.slice(1);

function readingTime(slug: string): string {
  // Approximate: 200 wpm
  return '5 min read';
}

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Cinturon360 Blog — Travel Tech & Industry Perspectives',
  url: 'https://cinturon360.com/blog',
  description: 'Articles on TMC operations, travel governance, NDC adoption, and the future of managed travel in APAC and beyond.',
  publisher: {
    '@type': 'Organization',
    name: 'Cinturon360',
    logo: { '@type': 'ImageObject', url: 'https://cinturon360.com/images/logo.png' },
  },
};
---

<PageLayout
  title="Blog — Travel Tech & Industry Perspectives"
  description="Articles on TMC operations, travel governance, NDC adoption, and the future of managed travel in APAC and beyond. Written by the team building Cinturon360."
  schema={schema}
>

  <!-- Hero -->
  <section
    class="relative overflow-hidden pt-32 pb-20 md:pb-24"
    style="background: var(--c360-dark);"
  >
    <div class="absolute -top-20 -left-20 w-96 h-96 rounded-full opacity-20 blur-3xl pointer-events-none" style="background: #38bdf8;"></div>
    <div class="absolute top-40 right-0 w-72 h-72 rounded-full opacity-10 blur-3xl pointer-events-none" style="background: #f97316;"></div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl relative">
      <div class="max-w-4xl mx-auto text-center">
        <div class="flex justify-center mb-8">
          <span class="hero-badge">
            <span class="w-1.5 h-1.5 rounded-full bg-sky-400 animate-pulse"></span>
            Perspectives
          </span>
        </div>
        <h1 class="font-heading text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
          From the team building<br />
          <span style="color: var(--c360-primary);">Cinturon</span><span style="color: var(--c360-accent);">360</span>.
        </h1>
        <p class="text-xl max-w-2xl mx-auto leading-relaxed" style="color: rgba(248,250,252,0.65);">
          Industry perspectives on TMC operations, travel governance, NDC adoption, and what modern managed travel looks like in APAC and beyond.
        </p>
      </div>
    </div>
  </section>

  <div class="section bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">

      {posts.length === 0 ? (
        <p class="text-slate-400 text-center py-16">No posts yet. Check back soon.</p>
      ) : (
        <div>
          <!-- Featured post -->
          {featured && (
            <a href={`/blog/${featured.id}`}
              class="group block rounded-2xl overflow-hidden mb-12 border border-slate-100 hover:shadow-xl transition-all duration-300"
              style="background: #f8fafc;">
              <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
                {featured.data.featured_image && (
                  <div class="overflow-hidden h-64 lg:h-auto lg:min-h-72">
                    <img
                      src={featured.data.featured_image}
                      alt={featured.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                  </div>
                )}
                <div class="p-8 lg:p-10 flex flex-col justify-center">
                  <div class="flex items-center gap-2 mb-4">
                    <span class="text-xs font-bold uppercase tracking-widest px-2.5 py-1 rounded-full"
                      style="background: rgba(56,189,248,0.1); color: #38bdf8; border: 1px solid rgba(56,189,248,0.2);">
                      Featured
                    </span>
                    {featured.data.categories?.slice(0,1).map((cat: string) => (
                      <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-slate-100 text-slate-600">
                        {cat}
                      </span>
                    ))}
                  </div>
                  <h2 class="font-heading text-2xl md:text-3xl font-bold text-slate-900 mb-3 leading-snug group-hover:text-sky-700 transition-colors">
                    {featured.data.title}
                  </h2>
                  <p class="text-slate-500 text-sm leading-relaxed mb-6 flex-1">
                    {featured.data.description}
                  </p>
                  <div class="flex items-center gap-3 text-xs text-slate-400">
                    <span class="font-medium text-slate-600">{featured.data.author}</span>
                    <span>·</span>
                    <time>{new Intl.DateTimeFormat('en-AU', { year: 'numeric', month: 'long', day: 'numeric' }).format(featured.data.date)}</time>
                    <span>·</span>
                    <span>5 min read</span>
                  </div>
                </div>
              </div>
            </a>
          )}

          <!-- Rest of posts -->
          {rest.length > 0 && (
            <div>
              <h2 class="font-heading text-xl font-bold text-slate-800 mb-6 pb-4 border-b border-slate-100">
                More articles
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {rest.map((post) => {
                  const formattedDate = new Intl.DateTimeFormat('en-AU', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  }).format(post.data.date);

                  return (
                    <article class="card flex flex-col group">
                      {post.data.featured_image && (
                        <div class="mb-4 rounded-xl overflow-hidden -mx-6 -mt-6 h-44">
                          <img
                            src={post.data.featured_image}
                            alt={post.data.title}
                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                          />
                        </div>
                      )}
                      <div class="flex flex-wrap gap-1.5 mb-2">
                        {post.data.categories?.slice(0,2).map((cat: string) => (
                          <span class="text-xs font-medium px-2.5 py-0.5 rounded-full bg-sky-50 text-sky-700 border border-sky-100">
                            {cat}
                          </span>
                        ))}
                      </div>
                      <h2 class="font-heading text-lg font-bold text-slate-900 mb-2 leading-snug group-hover:text-sky-700 transition-colors flex-1">
                        <a href={`/blog/${post.id}`}>{post.data.title}</a>
                      </h2>
                      <p class="text-sm text-slate-500 leading-relaxed mb-4 line-clamp-2">
                        {post.data.description}
                      </p>
                      <div class="flex items-center justify-between text-xs text-slate-400 pt-3 border-t border-slate-50">
                        <span class="font-medium text-slate-500">{post.data.author}</span>
                        <div class="flex items-center gap-2">
                          <time>{formattedDate}</time>
                          <span>· 5 min</span>
                        </div>
                      </div>
                    </article>
                  );
                })}
              </div>
            </div>
          )}
        </div>
      )}
    </div>
  </div>

  <CTA
    title="Want to stay in the loop?"
    description="Join the Cinturon360 waitlist and get updates as the platform evolves — including new articles, product milestones, and early access."
    primaryCTA={{ label: 'Join Waitlist', href: '/waitlist' }}
    secondaryCTA={{ label: 'Contact Us', href: '/contact' }}
  />
</PageLayout>
