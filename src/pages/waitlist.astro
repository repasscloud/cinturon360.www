---
import PageLayout from '../layouts/PageLayout.astro';
import WaitlistForm from '../components/sections/WaitlistForm.astro';
---

<PageLayout
  title="Join the Waitlist"
  description="Get early access to Cinturon360 — the modern operating layer for travel management companies. Join the waitlist today."
>

  <!-- Full-page dark layout -->
  <div class="min-h-screen flex flex-col" style="background: var(--c360-dark);">

    <!-- Background effects -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden">
      <div class="absolute -top-40 -left-40 w-[700px] h-[700px] rounded-full"
        style="background: radial-gradient(circle, rgba(56,189,248,0.1) 0%, transparent 65%);"></div>
      <div class="absolute -bottom-40 -right-40 w-[600px] h-[600px] rounded-full"
        style="background: radial-gradient(circle, rgba(249,115,22,0.08) 0%, transparent 65%);"></div>
      <div class="absolute inset-0 opacity-[0.025]"
        style="background-image: linear-gradient(rgba(255,255,255,1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px); background-size: 48px 48px;"></div>
    </div>

    <!-- Content -->
    <div class="flex-1 flex items-center justify-center pt-28 pb-16 px-4 relative z-10">
      <div class="w-full max-w-5xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

          <!-- Left: messaging -->
          <div>
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium mb-6"
              style="background: rgba(56,189,248,0.1); border: 1px solid rgba(56,189,248,0.2); color: #38bdf8;">
              <span class="w-1.5 h-1.5 rounded-full bg-sky-400 animate-pulse"></span>
              Early access — limited spots
            </div>

            <h1 class="font-heading font-extrabold text-white mb-5 leading-tight"
              style="font-size: clamp(2rem, 5vw, 3.25rem);">
              Be first when<br />
              <span style="color: var(--c360-primary);">Cinturon</span><span style="color: var(--c360-accent);">360</span> launches.
            </h1>

            <p class="text-base leading-relaxed mb-8" style="color: rgba(248,250,252,0.6);">
              We're building with a small group of TMCs and design partners now. Join the waitlist to follow development, express early commercial interest, and be first in line when access opens.
            </p>

            <!-- Benefits list -->
            <ul class="space-y-3 mb-10">
              {[
                { icon: '📬', text: 'Regular product and development updates' },
                { icon: '🎯', text: 'Priority access when we open TMC onboarding' },
                { icon: '🤝', text: 'Opportunity to join as a design partner' },
                { icon: '💡', text: 'Input into product direction and feature priorities' },
                { icon: '🌏', text: 'APAC-first launch — relevant for ANZ TMCs right now' },
              ].map((item) => (
                <li class="flex items-center gap-3 text-sm" style="color: rgba(248,250,252,0.65);">
                  <span class="text-base">{item.icon}</span>
                  {item.text}
                </li>
              ))}
            </ul>

            <!-- Social proof / trust signal -->
            <div class="rounded-xl p-4" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);">
              <p class="text-xs font-medium mb-1" style="color: rgba(248,250,252,0.4);">ANZ & APAC focused</p>
              <p class="text-sm" style="color: rgba(248,250,252,0.6);">
                <span style="color: var(--c360-primary);">Cinturon</span><span style="color: var(--c360-accent);">360</span> is built and hosted in Australia, targeting the ANZ TMC market first and expanding across APAC. Designed for how travel is managed in this region.
              </p>
            </div>
          </div>

          <!-- Right: form -->
          <div>
            <div class="rounded-2xl p-8"
              style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(12px);">
              <h2 class="font-heading text-xl font-bold text-white mb-1">Request early access</h2>
              <p class="text-sm mb-6" style="color: rgba(248,250,252,0.5);">
                Takes under 60 seconds.
              </p>
              <WaitlistForm />
            </div>

            <!-- Already a TMC? -->
            <div class="mt-4 text-center">
              <p class="text-sm" style="color: rgba(248,250,252,0.4);">
                Already running a TMC and want to talk?{' '}
                <a href="/contact" class="font-medium transition-colors hover:text-white" style="color: #38bdf8;">
                  Book a conversation →
                </a>
              </p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>

</PageLayout>
