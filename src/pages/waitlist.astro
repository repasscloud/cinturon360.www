---
import PageLayout from '../layouts/PageLayout.astro';
import WaitlistForm from '../components/sections/WaitlistForm.astro';
---

<PageLayout
  title="Join the Waitlist"
  description="Register your interest in Cinturon360 and receive updates as the platform moves toward launch."
>
  <div class="pt-24 pb-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <!-- Left -->
        <div>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-sky-100 text-sky-700 mb-4">
            Coming soon
          </span>
          <h1 class="font-heading text-4xl md:text-5xl font-bold text-slate-900 mb-4">
            Join the Cinturon360 waitlist
          </h1>
          <p class="text-lg text-slate-600 mb-8 leading-relaxed">
            Cinturon360 is currently in development. Register your interest and we'll be in touch as the platform moves toward launch.
          </p>

          <h2 class="font-heading text-lg font-semibold text-slate-900 mb-4">Joining the waitlist is suitable if you want to:</h2>
          <ul class="space-y-3">
            {[
              'Follow product and launch updates',
              'Express early commercial interest',
              'Discuss TMC or client use cases',
              'Hear about API and integration direction',
              'Be contacted about future access',
            ].map((item) => (
              <li class="flex items-start gap-3 text-slate-600">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-sky-400 flex-shrink-0"></span>
                <span class="text-sm">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Right: form -->
        <div>
          <div class="bg-slate-50 rounded-2xl p-8 border border-slate-100">
            <WaitlistForm />
          </div>
        </div>
      </div>
    </div>
  </div>
</PageLayout>
