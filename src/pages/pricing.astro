---
import PageLayout from '../layouts/PageLayout.astro';
import CTA from '../components/sections/CTA.astro';
---

<PageLayout
  title="Pricing"
  description="Cinturon360 pricing is tailored to your organisation. Contact us to discuss your program."
>
  <div class="pt-24 pb-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl text-center">
      <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-sky-100 text-sky-700 mb-4">
        Pricing
      </span>
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-slate-900 mb-6">
        Pricing built around your program
      </h1>
      <p class="text-xl text-slate-600 max-w-2xl mx-auto mb-12 leading-relaxed">
        Cinturon360 pricing is tailored to the size and structure of your travel program. We don't offer one-size-fits-all plans — we work with you to find the right model.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto mb-16">
        {[
          { icon: '🏢', title: 'TMCs', description: 'Commercial structures designed for travel management companies onboarding and managing multiple client programs.' },
          { icon: '💼', title: 'Corporate Programmes', description: 'Pricing for organisations deploying Cinturon360 to govern travel approvals, policy, and visibility across teams and entities.' },
          { icon: '🏛️', title: 'Government & Enterprise', description: 'Flexible arrangements for controlled environments requiring audit-grade governance, structured approvals, and strong reporting.' },
        ].map((tier) => (
          <div class="card text-center">
            <div class="text-4xl mb-4">{tier.icon}</div>
            <h3 class="font-heading text-xl font-bold text-slate-900 mb-3">{tier.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed mb-6">{tier.description}</p>
            <a
              href="/contact"
              class="inline-flex items-center justify-center w-full px-6 py-3 rounded-full font-semibold text-sm border border-sky-400 text-sky-600 hover:bg-sky-50 transition-colors"
            >
              Get in touch
            </a>
          </div>
        ))}
      </div>

      <div class="max-w-2xl mx-auto bg-slate-50 rounded-2xl border border-slate-100 p-8">
        <h2 class="font-heading text-2xl font-bold text-slate-900 mb-3">Ready to discuss pricing?</h2>
        <p class="text-slate-600 mb-6">
          Cinturon360 is currently in development and accepting early expressions of interest. Reach out to start a conversation about your travel program.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/contact" class="btn-primary">Book a Conversation</a>
          <a href="/waitlist" class="btn-outline !text-slate-700 !border-slate-300 !bg-transparent hover:!bg-slate-100">Join Waitlist</a>
        </div>
      </div>
    </div>
  </div>

  <CTA />
</PageLayout>
